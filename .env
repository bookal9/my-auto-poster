# TikTok Auto Poster Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# DO NOT commit the actual .env file to version control

# TikTok API Credentials
# Get these from the TikTok Developer Portal: https://developers.tiktok.com/
TIKTOK_API_KEY=your_tiktok_api_key_here
TIKTOK_API_SECRET=your_tiktok_api_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# Your TikTok Account Information
TIKTOK_USERNAME=your_tiktok_username_here

# Gmail SMTP Credentials for Error Notifications
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here
